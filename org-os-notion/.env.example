# Server Configuration
PORT=3001

# Notion Configuration
# Paste your Notion Integration Token (secret_...) here:
NOTION_INTEGRATION_TOKEN=

# Paste your Notion Root Page ID (UUID from URL) here:
NOTION_ROOT_PAGE_ID=

# Gemini API Configuration
# Paste your Google Gemini API Key here:
GEMINI_API_KEY=

# Mock Notion Fallback (default: true)
# Set to 'false' to connect to real Notion API, or 'true' to use local file-based mock databases
MOCK_NOTION=true
